{
  "name": "mono-dev",
  "version": "0.4.6",
  "description": "NPM module for mono-dev utilities",
  "type": "module",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@prettier/cli": "^0.10.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "typedoc": "^0.28.19",
    "typedoc-theme-oxide": "^0.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/which": "^3.0.4",
    "rolldown": "1.0.0-rc.12",
    "which": "^6.0.1"
  },
  "bin": {
    "vite": "./bin/vite.js",
    "vitest": "./bin/vitest.js",
    "mono": "./bin/mono.js"
  },
  "files": [
    "bin/**/*",
    "dist/**/*",
    "lib/**/*",
    "mdbook/**/*",
    "scripts/**/*",
    "src/**/*",
    "task/**/*",
    "toolsets/**/*",
    "types/**/*",
    "dist/**/*"
  ],
  "exports": {
    "./vite": "./lib/vite.js",
    "./vitest": "./lib/vitest.js",
    "./lib-types": "./types/lib_types.d.ts",
    "./app-types": "./types/app_types.d.ts",
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/_dts_/src/cli/index.d.ts"
    },
    "./eslint-config": {
      "import": "./dist/config/configure_eslint.js",
      "types": "./dist/_dts_/src/config/configure_eslint.d.ts"
    },
    "./lib-build-config": {
      "import": "./dist/config/configure_lib_build.js",
      "types": "./dist/_dts_/src/config/configure_lib_build.d.ts"
    },
    "./app-build-config": {
      "import": "./dist/config/configure_app_build.js",
      "types": "./dist/_dts_/src/config/configure_app_build.d.ts"
    }
  },
  "imports": {
    "#cli": "./dist/_dts_/src/cli/index.d.ts",
    "#config": "./dist/_dts_/src/config/index.d.ts",
    "#plugins": "./dist/_dts_/src/plugins/index.d.ts",
    "#project": "./dist/_dts_/src/project/index.d.ts",
    "#util": "./dist/_dts_/src/util/index.d.ts"
  }
}