{
    "name": "mono-dev",
    "version": "0.4.21",
    "description": "NPM module for mono-dev utilities",
    "private": true,
    "type": "module",
    "dependencies": {
        "@babel/core": "^7.29.7",
        "@eslint/js": "^9.39.4",
        "@prettier/cli": "^0.12.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260421.2",
        "@vitejs/plugin-react": "^6.0.3",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "js-yaml": "^4.3.0",
        "jsdom": "^29.1.1",
        "typedoc": "^0.28.20",
        "typedoc-theme-oxide": "^0.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.3",
        "vite-plugin-wasm": "^3.6.0",
        "vitest": "^4.1.9"
    },
    "devDependencies": {
        "@types/babel__core": "^7.20.5",
        "@types/bun": "^1.3.14",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^24",
        "@types/which": "^3.0.4",
        "rolldown": "^1.1.4",
        "which": "^6.0.1"
    },
    "bin": {
        "vite": "./bin/vite.js",
        "vitest": "./bin/vitest.js",
        "mono": "./bin/mono.js"
    },
    "files": [
        "bin/**/*",
        "dist/**/*",
        "lib/**/*",
        "mdbook/**/*",
        "scripts/**/*",
        "src/**/*",
        "task/**/*",
        "toolsets/**/*",
        "types/**/*"
    ],
    "exports": {
        "./vite": "./lib/vite.js",
        "./vitest": "./lib/vitest.js",
        "./lib-types": "./types/lib_types.d.ts",
        "./app-types": "./types/app_types.d.ts",
        "./cli": {
            "import": "./dist/cli/index.js",
            "types": "./dist/_dts_/src/cli/index.d.ts"
        },
        "./eslint-config": "./src/config/configure_eslint.ts",
        "./lib-build-config": "./src/config/configure_lib_build.ts",
        "./app-build-config": "./src/config/configure_app_build.ts",
        "./rolldown": "./src/rolldown.ts"
    },
    "imports": {
        "#cli": "./src/cli/index.ts",
        "#config": "./src/config/index.ts",
        "#plugins": "./src/plugins/index.ts",
        "#project": "./src/project/index.ts",
        "#util": "./src/util/index.ts"
    },
    "pistonight/mono-dev": {
        "lib": "node",
        "nocheck": [
            "/mdbook"
        ],
        "compile": {
            "./cli": "./src/cli/index.ts"
        },
        "import.meta.env": {
            "VERSION": true,
            "COMMIT": true
        }
    }
}
