{
    "name": "mono-dev",
    "version": "0.3.19",
    "description": "NPM module for mono-dev utilities",
    "private": true,
    "type": "module",
    "files": [
        "task/**/*"
    ],
    "dependencies": {
        "@babel/core": "^7.29.0",
        "@eslint/js": "^9.39.4",
        "@prettier/cli": "^0.10.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@typescript/native-preview": "7.0.0-dev.20250530.1",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "cheerio": "^1.1.2",
        "eslint": "^9.39.4",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "flexsearch": "^0.8.212",
        "globals": "^17.5.0",
        "js-yaml": "^4.1.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "slug": "^11.0.1",
        "typedoc": "^0.28.19",
        "typedoc-theme-oxide": "^0.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.10",
        "vite-plugin-wasm": "^3.6.0",
        "vitest": "^4.1.5"
    },
    "devDependencies": {
        "@types/babel__core": "^7.20.5",
        "@types/bun": "^1.3.13",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/which": "^3.0.4",
        "rolldown": "1.0.0-rc.12",
        "which": "^6.0.1"
    },
    "bin": {
        "vite": "./bin/vite.js",
        "monolint": "./toolsets/js/src/monolint_main.js",
        "monolibbuild": "./toolsets/js/src/libbuild_main.js",
        "monotest": "./toolsets/js/src/monotest_main.js",
        "monotypedoc": "./toolsets/js/src/monotypedoc_main.js",
        "monotaskfile": "./toolsets/js/src/monotaskfile.js"
    },
    "exports": {
        "./vite": "./lib/vite.js",
        "./vitest": "./lib/vitest.js",
        "./lib-types": "./types/lib_types.d.ts",
        "./app-types": "./types/app_types.d.ts",
        "./cli": {
            "import": "./dist/cli/index.js",
            "types": "./dist/_dts/src/cli/index.d.ts"
        },
        "./eslint-config": {
            "import": "./dist/config/configure_eslint.js",
            "types": "./dist/_dts_/src/config/configure_eslint.d.ts"
        },
        "./lib-build-config": {
            "import": "./dist/config/configure_lib_build.js",
            "types": "./dist/_dts_/src/config/configure_lib_build.d.ts"
        },
        "./test-config": {
            "import": "./dist/config/configure_vitest.js",
            "types": "./dist/_dts/src/config/configure_vitest.d.ts"
        },
        "./vite-config": "./toolsets/js/src/vite_config.js",
        "./toolsets/js/typescript/default-tsconfig.json": "./toolsets/js/typescript/default-tsconfig.json"
    },
    "imports": {
        "#util": "./src/util/index.ts",
        "#plugins": "./src/plugins/index.ts",
        "#config": "./src/config/index.ts",
        "#project": "./src/project/index.ts"
    },
    "nocheck": [
        "/mdbook/css",
        "/mdbook/theme",
        "/toolsets/mdbook"
    ]
}
